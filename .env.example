# ATLAS environment template — copy to `.env.local` for local dev.
#
# All `VITE_*` values are baked into the browser bundle at build time.
# Server-only secrets (e.g. BigQuery service account JSON) live in
# Vercel project settings and are NEVER prefixed with VITE_.

# ── Globe basemap ───────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAP3D_MAP_ID=

# ── BigQuery backend for historical analytics ───────────────────────
# Points the client at `vercel dev --listen 3001` during local development.
# In production leave unset: the client calls `/api/*` on the same origin.
VITE_ATLAS_API_BASE=http://localhost:3001

# ── Server-only (set in Vercel dashboard, NOT here for prod) ────────
# Service account JSON (single-line, JSON-stringified).
# GOOGLE_CLOUD_CREDENTIALS=
# GOOGLE_CLOUD_PROJECT=
# Optional guard: reject BigQuery queries whose dryRun estimate
# exceeds this many bytes. Default 500_000_000 (500 MB).
# ATLAS_MAX_SCAN_BYTES=500000000

# ── Optional data source keys ───────────────────────────────────────
# Client-side (dev / fallback). In production prefer server-only keys below.
VITE_NEWSAPI_KEY=
VITE_NEWS_API_KEY=
VITE_GNEWS_KEY=
VITE_THENEWSAPI_KEY=
VITE_YOUTUBE_API_KEY=
VITE_FIRMS_MAP_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server-only news keys (Vercel — NOT VITE_ prefixed) ─────────────
# Used by /api/news-proxy so keys never ship in the browser bundle.
NEWSAPI_KEY=
GNEWS_API_KEY=
THENEWSAPI_KEY=
YOUTUBE_API_KEY=
# Restrict browser news calls to proxy in local dev (optional):
# VITE_NEWS_PROXY=true
# Server-only — required for L2 feed_snapshots writes (never VITE_ prefix)
# SUPABASE_SERVICE_ROLE_KEY=

# ── Phase 3 maritime (server-only — NOT VITE_ prefixed) ───────────────
# AISStream.io free tier: register at https://aisstream.io, create API key.
# Used by /api/aisstream-ships (browser cannot connect to AISStream directly).
AISSTREAM_API_KEY=

# ── Phase 6 stretch (server-only — NOT VITE_ prefixed) ────────────────
# Google Fact Check Tools API — free tier at Google Cloud Console.
# Used by /api/fact-check-claims for ClaimReview overlay + EventPanel lookup.
GOOGLE_FACT_CHECK_API_KEY=

# ── Outbound alerts (Supabase Edge Function send-alert) ───────────────
# Deploy supabase/functions/send-alert and set in Supabase project secrets.
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# ALERT_FROM_EMAIL=alerts@atlas-intel.app
