<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{title}} — ATLAS Report</title>
  <style>{{> printStyles}}</style>
</head>
<body class="atlas-report atlas-report--general">
  <header class="report-header">
    <h1>{{title}}</h1>
    <p class="report-meta">OSINT Summary · {{generatedAt}}{{#if provenance.place}} · {{provenance.place}}{{/if}}</p>
  </header>

  {{#each sections}}
  <section class="report-section report-section--{{kind}}">
    <h2>{{title}}</h2>
    {{#if body}}<div class="report-body">{{{bodyHtml}}}</div>{{/if}}
    {{#if rows}}
    {{#if (eq kind "evidence")}}
    <ul class="report-signals">
      {{#each rows}}
      <li><strong>{{title}}</strong> — {{priority}} · {{dimension}} · {{source}}{{#if lowConfidence}} <em>(low confidence)</em>{{/if}}</li>
      {{/each}}
    </ul>
    {{/if}}
    {{#if (eq kind "timeline")}}
    <ul class="report-timeline">
      {{#each rows}}<li>{{date}} — {{title}}</li>{{/each}}
    </ul>
    {{/if}}
    {{#if (eq kind "sources")}}
    <ul class="report-sources">{{#each rows}}<li>{{name}} ({{count}})</li>{{/each}}</ul>
    {{/if}}
    {{/if}}
  </section>
  {{/each}}

  {{#if snapshots.canvasPng}}
  <section class="report-section"><h2>Connection Diagram</h2><img src="{{snapshots.canvasPng}}" alt="Canvas" class="report-map" /></section>
  {{/if}}

  <footer class="report-footer">Generated by ATLAS · {{generatedAt}} · {{provenance.sourceCount}} sources</footer>
</body>
</html>
