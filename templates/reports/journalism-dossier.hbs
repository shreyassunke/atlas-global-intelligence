<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{title}} — Investigation Dossier</title>
  <style>{{> printStyles}}</style>
</head>
<body class="atlas-report atlas-report--journalism">
  <header class="report-header">
    <h1>{{title}}</h1>
    <p class="report-meta">Investigation Dossier · {{generatedAt}}</p>
  </header>

  {{#each sections}}
  <section class="report-section report-section--{{kind}}">
    <h2>{{title}}</h2>
    {{#if body}}<div class="report-body">{{{bodyHtml}}}</div>{{/if}}
    {{#if rows}}
    {{#if (eq kind "timeline")}}
    <ol class="report-chronology">
      {{#each rows}}<li><time>{{date}} {{time}}</time> — {{title}}</li>{{/each}}
    </ol>
    {{/if}}
    {{#if (eq kind "evidence")}}
    <table class="report-table">
      <thead><tr><th>Item</th><th>Type</th><th>Source</th><th>Notes</th></tr></thead>
      <tbody>
        {{#each rows}}
        <tr{{#if lowConfidence}} class="low-confidence"{{/if}}>
          <td>{{title}}</td><td>{{kind}}</td><td>{{source}}</td>
          <td>{{#if lowConfidence}}Unverified — low corroboration{{else}}—{{/if}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{/if}}
    {{#if (eq kind "sources")}}
    <table class="report-table report-table--ledger">
      <thead><tr><th>Source</th><th>Count</th><th>URL</th></tr></thead>
      <tbody>{{#each rows}}<tr><td>{{name}}</td><td>{{count}}</td><td>{{url}}</td></tr>{{/each}}</tbody>
    </table>
    {{/if}}
    {{/if}}
  </section>
  {{/each}}

  <footer class="report-footer">Source ledger · Generated by ATLAS · {{generatedAt}}</footer>
</body>
</html>
