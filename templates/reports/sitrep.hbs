<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{title}} — ATLAS SITREP</title>
  <style>{{> printStyles}}</style>
</head>
<body class="atlas-report atlas-report--sitrep">
  <header class="report-header">
    <div class="report-classification">{{classificationLabel}}</div>
    <h1>{{title}}</h1>
    <p class="report-meta">SITREP · {{generatedAt}} · {{provenance.place}}</p>
  </header>

  {{#each sections}}
  <section class="report-section report-section--{{kind}}">
    <h2>{{title}}</h2>
    {{#if body}}<div class="report-body">{{{bodyHtml}}}</div>{{/if}}
    {{#if rows}}
    {{#if (eq kind "evidence")}}
    <table class="report-table">
      <thead><tr><th>Signal</th><th>Priority</th><th>Dimension</th><th>Source</th><th>Conf.</th></tr></thead>
      <tbody>
        {{#each rows}}
        <tr{{#if lowConfidence}} class="low-confidence"{{/if}}>
          <td>{{title}}{{#if lowConfidence}} ⚠{{/if}}</td>
          <td>{{priority}}</td>
          <td>{{dimension}}</td>
          <td>{{source}}</td>
          <td>{{confidence}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{/if}}
    {{#if (eq kind "timeline")}}
    <ul class="report-timeline">
      {{#each rows}}<li><strong>{{date}} {{time}}</strong> — {{title}} <span class="muted">({{source}})</span></li>{{/each}}
    </ul>
    {{/if}}
    {{#if (eq kind "sources")}}
    <ul class="report-sources">
      {{#each rows}}<li>{{name}} — {{count}} items{{#if url}} · {{url}}{{/if}}</li>{{/each}}
    </ul>
    {{/if}}
    {{/if}}
  </section>
  {{/each}}

  {{#if snapshots.globePng}}
  <section class="report-section report-section--map">
    <h2>Map Snapshot</h2>
    <img src="{{snapshots.globePng}}" alt="Globe snapshot" class="report-map" />
  </section>
  {{/if}}

  <footer class="report-footer">
    Generated by ATLAS · {{generatedAt}} · {{provenance.sourceCount}} sources · Rev {{provenance.revision}}
  </footer>
</body>
</html>
